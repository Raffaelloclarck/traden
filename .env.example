# === MODE ===
# paper = simulatie (standaard, veilig)
# live  = echte orders (alleen als je API keys invult)
TRADING_MODE=paper

# === RISK ===
MAX_RISK_PER_TRADE_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
MAX_OPEN_POSITIONS=5

# === CRYPTO (via CCXT) ===
# Ondersteunt o.a. binance, kraken, bybit, coinbase
CRYPTO_EXCHANGE=binance
CRYPTO_API_KEY=
CRYPTO_API_SECRET=
# true = testnet/sandbox waar beschikbaar
CRYPTO_SANDBOX=true

# === US STOCKS (Alpaca) ===
ALPACA_API_KEY=
ALPACA_API_SECRET=
# https://paper-api.alpaca.markets (paper) of https://api.alpaca.markets (live)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === WATCHLIST (komma-gescheiden) ===
CRYPTO_SYMBOLS=ETH/USDT
STOCK_SYMBOLS=AAPL

# === ML PRECISION ===
ML_BUY_THRESHOLD=0.75
ML_SELL_THRESHOLD=0.35
ML_PRECISION_MODE=true
ML_MONTHS=12

# === TRADINGVIEW WEBHOOK ===
# Genereer een willekeurig secret, bijv: openssl rand -hex 16
TV_WEBHOOK_SECRET=
TV_MODE=false
